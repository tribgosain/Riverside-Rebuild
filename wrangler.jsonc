{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "riverside-rebuild",
  "compatibility_date": "2026-07-20",
  // No "main" entry point on purpose — this is a static-assets-only Worker,
  // not a Functions/dynamic Worker, so it's served on the free, unlimited-
  // bandwidth static assets path rather than metered request billing.
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
